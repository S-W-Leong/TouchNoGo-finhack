{
  "policy_version": "2026-04-25-demo-v1",
  "seed_version": "2026-04-25-demo-v1",
  "thresholds": {
    "watchlist_similarity_warning": 0.88,
    "watchlist_similarity_hard_block": 0.95,
    "new_device_age_hours": 24,
    "wallet_reactivation_window_hours": 72,
    "amount_to_30d_avg_hold_ratio": 4.0
  },
  "editable_in_scenario_lab": [
    "watchlist_similarity_warning",
    "amount_to_30d_avg_hold_ratio"
  ],
  "policies": [
    {
      "policy_id": "POL-FRD-12",
      "name": "First cross-border payout on recent device or reactivated wallet",
      "category": "FRAUD",
      "severity": "HIGH",
      "default_action": "HOLD",
      "override_actions": [
        "STEP_UP",
        "ESCALATE",
        "ALLOW"
      ],
      "condition": {
        "all": [
          {
            "field": "transaction.is_cross_border",
            "operator": "==",
            "value": true
          },
          {
            "field": "transaction.is_first_payout_to_beneficiary",
            "operator": "==",
            "value": true
          },
          {
            "field": "transaction.amount_to_30d_avg_ratio",
            "operator": ">=",
            "value": 4.0
          },
          {
            "any": [
              {
                "field": "device.age_hours",
                "operator": "<=",
                "value": 24
              },
              {
                "field": "wallet.hours_since_reactivation",
                "operator": "<=",
                "value": 72
              }
            ]
          }
        ]
      },
      "explanation_template": "First cross-border payout with a large amount shift and recent account or device change requires a hold for review."
    },
    {
      "policy_id": "POL-AML-07",
      "name": "Near-watchlist beneficiary on outbound payout",
      "category": "AML",
      "severity": "HIGH",
      "default_action": "HOLD",
      "override_actions": [
        "STEP_UP",
        "ESCALATE",
        "ALLOW"
      ],
      "condition": {
        "all": [
          {
            "field": "beneficiary.watchlist_similarity",
            "operator": ">=",
            "value": 0.88
          },
          {
            "field": "beneficiary.watchlist_similarity",
            "operator": "<",
            "value": 0.95
          },
          {
            "field": "transaction.is_cross_border",
            "operator": "==",
            "value": true
          }
        ]
      },
      "explanation_template": "Beneficiary similarity is above the warning threshold but below the hard-block threshold, so the payout must be reviewed."
    },
    {
      "policy_id": "POL-OPS-04",
      "name": "Human approval required for hold and escalate",
      "category": "OPERATIONS",
      "severity": "MANDATORY",
      "default_action": "HOLD",
      "override_actions": [
        "STEP_UP",
        "ESCALATE",
        "ALLOW"
      ],
      "condition": {
        "any": [
          {
            "field": "recommendation.action",
            "operator": "==",
            "value": "HOLD"
          },
          {
            "field": "recommendation.action",
            "operator": "==",
            "value": "ESCALATE"
          }
        ]
      },
      "explanation_template": "Any hold or escalation action must remain human-approved and auditable."
    }
  ]
}
